{
  "name": "@runwayml/avatars-react",
  "version": "0.17.0",
  "description": "React SDK for real-time AI avatar interactions with GWM-1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./api": {
      "import": {
        "types": "./dist/api.d.ts",
        "default": "./dist/api.js"
      },
      "require": {
        "types": "./dist/api.d.cts",
        "default": "./dist/api.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "typesVersions": {
    "*": {
      "api": ["./dist/api.d.ts"]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICES"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "mkdir -p dist && cp src/styles.css dist/styles.css && tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/",
    "test": "bun test"
  },
  "keywords": [
    "runwayml",
    "avatar",
    "ai",
    "react",
    "hooks",
    "realtime",
    "gwm-1",
    "video",
    "webrtc",
    "streaming"
  ],
  "author": "RunwayML",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@runwayml/avatars": "^0.17.0",
    "@livekit/components-react": "^2.9.19",
    "livekit-client": "^2.18.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
