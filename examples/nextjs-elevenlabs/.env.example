# Runway API secret (required)
# Get yours at https://dev.runwayml.com/
RUNWAYML_API_SECRET=

# ElevenLabs API key (required, needs ElevenAgents read permission)
# Get yours at https://elevenlabs.io/
ELEVENLABS_API_KEY=

# ElevenLabs Conversational AI agent ID (required)
# Create an agent at https://elevenlabs.io/app/agents/agents
# Set "User input audio format" to "PCM 16000Hz" in Advanced settings
ELEVENLABS_AGENT_ID=

# Custom avatar ID (required)
# Create one at https://dev.runwayml.com/ under Characters > Avatars
RUNWAY_AVATAR_ID=

# Optional: override Runway API base URL (for staging testing)
# RUNWAYML_BASE_URL=https://api.dev-stage.runwayml.com
# NEXT_PUBLIC_RUNWAYML_BASE_URL=https://api.dev-stage.runwayml.com
