# Runway API secret (required)
# Create at https://dev.runwayml.com/ (prod) or https://dev-stage.runwayml.com/ (stage)
RUNWAYML_API_SECRET=

# Custom avatar ID (required) — must appear in GET /v1/avatars for your API key
# See README "Avatar ID" section. Devportal URLs alone are not enough.
RUNWAY_AVATAR_ID=

# Optional Runway API base URL (defaults to https://api.dev.runwayml.com)
# RUNWAY_API_BASE_URL=https://api.dev-stage.runwayml.com

# ElevenLabs API key (required, server-side only; needs ElevenAgents read permission)
# https://elevenlabs.io/
ELEVENLABS_API_KEY=

# ElevenLabs Conversational AI agent ID (required)
# Create at https://elevenlabs.io/app/agents/agents
# Advanced → User input audio format → PCM 16000Hz
ELEVENLABS_AGENT_ID=
